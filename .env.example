# Base SQLite demo para abrir el dashboard sin ejecutar scraping.
DATABASE_PATH=data/demo_observatorio.db

# Alternativa SQLAlchemy completa. Si DATABASE_URL existe, tiene prioridad sobre DATABASE_PATH.
# DATABASE_URL=sqlite:///data/observatorio_ane.db
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/observatorio_ane

# Timeout sugerido para ejecuciones manuales de scraping.
REQUEST_TIMEOUT_SECONDS=90
